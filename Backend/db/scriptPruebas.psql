-- =============================================================================
-- SECCIÓN 11: CONSULTAS DE VALIDACIÓN GENERAL
-- =============================================================================

-- 11.1 Resumen de inventario por empresa (verificar aislamiento multitenant)
SELECT '=== INVENTARIO POR EMPRESA ===' AS reporte;
SELECT e.nombre AS empresa, s.nombre AS sucursal, p.nombre AS producto,
       p.stock_actual, p.costo_promedio, p.precio_venta,
       ROUND((p.precio_venta - p.costo_promedio)::numeric, 2) AS margen_unitario
FROM producto p
JOIN empresa e ON e.id = p.empresa_id
JOIN sucursal s ON s.id = p.sucursal_id
ORDER BY e.id, p.id;

-- 11.2 Estado de cuentas por cobrar
SELECT '=== CUENTAS POR COBRAR ===' AS reporte;
SELECT e.nombre AS empresa, c.nombre AS cliente,
       cl.saldo_actual AS saldo_en_cliente,
       SUM(v.saldo_pendiente) AS saldo_en_ventas
FROM cliente cl
JOIN empresa e ON e.id = cl.empresa_id
JOIN cliente c ON c.id = cl.id
LEFT JOIN venta v ON v.cliente_id = cl.id AND v.saldo_pendiente > 0
GROUP BY e.nombre, c.nombre, cl.saldo_actual
ORDER BY e.nombre;

-- 11.3 Estado de cuentas por pagar
SELECT '=== CUENTAS POR PAGAR (PROVEEDORES) ===' AS reporte;
SELECT e.nombre AS empresa, pr.nombre AS proveedor,
       co.id AS compra_id, co.total, co.total_pagado, co.saldo_pendiente, co.estado
FROM compra co
JOIN empresa e ON e.id = co.empresa_id
JOIN proveedor pr ON pr.id = co.proveedor_id
ORDER BY e.id, co.id;

-- 11.4 Rentabilidad de ventas
SELECT '=== RENTABILIDAD DE VENTAS ===' AS reporte;
SELECT e.nombre AS empresa, v.id AS venta_id,
       v.total, v.utilidad_total,
       ROUND((v.utilidad_total / NULLIF(v.total, 0) * 100)::numeric, 2) AS margen_pct,
       v.estado
FROM venta v
JOIN empresa e ON e.id = v.empresa_id
ORDER BY e.id, v.id;

-- 11.5 Kardex completo con saldos
SELECT '=== KARDEX COMPLETO ===' AS reporte;
SELECT e.nombre AS empresa, p.nombre AS producto,
       k.tipo_movimiento, k.cantidad, k.costo_unitario,
       k.stock_anterior, k.stock_resultante, k.referencia, k.fecha
FROM kardex k
JOIN empresa e ON e.id = k.empresa_id
JOIN producto p ON p.id = k.producto_id
ORDER BY e.id, k.id;

-- 11.6 Verificación de aislamiento multitenant
-- Ningún cliente, producto o usuario de empresa 1 debe aparecer en empresa 2 y viceversa
SELECT '=== VERIFICACIÓN AISLAMIENTO MULTITENANT ===' AS reporte;
SELECT 'Empresa 1 - clientes' AS entidad, COUNT(*) AS total FROM cliente WHERE empresa_id = 1
UNION ALL
SELECT 'Empresa 2 - clientes', COUNT(*) FROM cliente WHERE empresa_id = 2
UNION ALL
SELECT 'Empresa 1 - productos', COUNT(*) FROM producto WHERE empresa_id = 1
UNION ALL
SELECT 'Empresa 2 - productos', COUNT(*) FROM producto WHERE empresa_id = 2
UNION ALL
SELECT 'Empresa 1 - ventas',    COUNT(*) FROM venta   WHERE empresa_id = 1
UNION ALL
SELECT 'Empresa 2 - ventas',    COUNT(*) FROM venta   WHERE empresa_id = 2;

-- 11.7 Consistencia del kardex (stock_resultante del último movimiento = stock_actual en producto)
SELECT '=== CONSISTENCIA KARDEX vs PRODUCTO ===' AS reporte;
SELECT p.nombre,
       p.stock_actual AS stock_en_producto,
       k_last.stock_resultante AS ultimo_kardex,
       CASE WHEN p.stock_actual = k_last.stock_resultante THEN 'OK ✓' ELSE 'DISCREPANCIA ✗' END AS estado
FROM producto p
JOIN LATERAL (
    SELECT stock_resultante
    FROM kardex
    WHERE producto_id = p.id
    ORDER BY id DESC
    LIMIT 1
) k_last ON TRUE
ORDER BY p.empresa_id, p.id;

-- 11.8 Log de licencias activas
SELECT '=== LICENCIAS ACTIVAS ===' AS reporte;
SELECT e.nombre AS empresa, l.token, l.estado,
       l.fecha_activacion::date AS activacion,
       l.fecha_vencimiento::date AS vencimiento,
       (l.fecha_vencimiento - NOW())::text AS tiempo_restante
FROM licencia_token l
JOIN empresa e ON e.id = l.empresa_id
ORDER BY e.id;