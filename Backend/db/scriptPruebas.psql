-- =============================================================================
-- SECCIÓN 5: PRUEBA TRIGGER T1 - COMPRAS E INVENTARIO (costo promedio + kardex)
-- =============================================================================
-- Escenario: Empresa 1 realiza una compra con 3 productos.
-- Verificar: stock_actual sube, costo_promedio se recalcula, kardex se inserta.

-- Estado inicial del stock (debería ser 0 para todos)
SELECT 'PRE-COMPRA empresa 1' AS momento, id, nombre, stock_actual, costo_promedio
FROM producto WHERE empresa_id = 1 AND sucursal_id = 1 ORDER BY id;

INSERT INTO compra (empresa_id, proveedor_id, sucursal_id, usuario_id, fecha, subtotal, impuesto, total, estado, saldo_pendiente)
VALUES (1, 1, 1, 1, NOW(), 420000, 79800, 499800, 'PENDIENTE', 499800);

-- Items de compra: el trigger T1 se dispara por cada INSERT
INSERT INTO item_compra (compra_id, producto_id, cantidad, costo_unitario, subtotal) VALUES
    (1, 3, 100, 14000, 1400000),  -- 100 bolsas arroz
    (1, 4,  50,  4000,  200000),  -- 50 frijol
    (1, 5,  30,  3000,   90000);  -- 30 jabón

-- Verificar post-compra: stock y costo promedio actualizados
SELECT 'POST-COMPRA empresa 1' AS momento, id, nombre, stock_actual, costo_promedio
FROM producto WHERE empresa_id = 1 AND sucursal_id = 1 ORDER BY id;

-- Verificar kardex generado por T1
SELECT 'KARDEX compra' AS check_, k.tipo_movimiento, p.nombre, k.cantidad,
       k.stock_anterior, k.stock_resultante, k.referencia
FROM kardex k JOIN producto p ON p.id = k.producto_id
WHERE k.empresa_id = 1
ORDER BY k.id;

-- Compra empresa 1 con lácteos (proveedor 2)
