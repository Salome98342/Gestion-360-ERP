-- =============================================================================
-- SECCIÓN 0: LIMPIEZA PREVIA (orden inverso de dependencias)
-- =============================================================================

TRUNCATE TABLE log_actividad, auditoria_descuento, movimiento_caja, kardex,
    abono, pago_proveedor, item_venta, item_compra,
    venta, compra, caja, producto, proveedor, cliente, tipo_cliente, categoria,
    usuario, rol, sucursal, renovacion_licencia, licencia_token, secuencias, empresa
RESTART IDENTITY CASCADE;


