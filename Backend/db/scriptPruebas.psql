-- =============================================================================
-- PRUEBA DE COSTO PROMEDIO PONDERADO (segunda compra del mismo producto)
-- =============================================================================
-- Empresa 1 hace una segunda compra de arroz a precio diferente.
-- El trigger T1 debe recalcular costo_promedio = ((stock_actual * costo_anterior) + (nueva_cant * nuevo_costo)) / nuevo_stock_total

SELECT 'PRE-2da compra arroz' AS momento, stock_actual, costo_promedio FROM producto WHERE id = 3;

INSERT INTO compra (empresa_id, proveedor_id, sucursal_id, usuario_id, fecha, subtotal, impuesto, total, estado, saldo_pendiente)
VALUES (1, 1, 1, 1, NOW(), 210000, 39900, 249900, 'PENDIENTE', 249900);

INSERT INTO item_compra (compra_id, producto_id, cantidad, costo_unitario, subtotal)
VALUES (4, 3, 50, 15000, 750000);   -- 50 bolsas a $15.000 (era $14.000)
-- Costo promedio esperado: ((100*14000) + (50*15000)) / 150 = 2150000/150 = $14.333,33

SELECT 'POST-2da compra arroz — costo promedio esperado ~14333' AS check_, stock_actual, costo_promedio
FROM producto WHERE id = 3;


